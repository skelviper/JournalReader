{
  "name": "@journal-reader/desktop",
  "productName": "Journal Reader",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "npm run clean:dev && npm run build:main && concurrently -k \"npm:dev:main\" \"npm:dev:renderer\" \"npm:dev:electron\"",
    "clean:dev": "rm -rf dist/main dist/preload tsconfig.main.tsbuildinfo tsconfig.preload.tsbuildinfo",
    "dev:main": "tsc -w -p tsconfig.main.json",
    "dev:renderer": "vite",
    "dev:electron": "wait-on --timeout 60000 tcp:127.0.0.1:5173 file:dist/main/index.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "vite build",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "rebuild:native": "cross-env HOME=../../.electron-home npm_config_devdir=../../.electron-gyp electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@journal-reader/parser": "0.1.0",
    "@journal-reader/pdf-core": "0.1.0",
    "@journal-reader/storage": "0.1.0",
    "@journal-reader/types": "0.1.0",
    "@journal-reader/ui": "0.1.0",
    "electron": "^33.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron-rebuild": "^3.2.9",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  }
}
